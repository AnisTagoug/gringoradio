# ─────────────────────────────────────────────
# RadioStudio — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL (Neon or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Cloudflare R2 (free cloud audio storage) ───────────────────────────────
# 1. Go to Cloudflare dashboard → R2 → Create bucket (e.g. "radiostudio-audio")
# 2. Enable "Public access" on the bucket → copy the public URL
# 3. Go to R2 → Manage API tokens → Create token (Object Read & Write)
# 4. Copy Account ID from R2 Overview page

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=radiostudio-audio
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXX.r2.dev

# ─── Icecast ─────────────────────────────────────────────────────────────────
ICECAST_HOST=localhost
ICECAST_PORT=8040
ICECAST_INTERNAL_PORT=8000
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=adminpass123
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_CONTAINER_NAME=radiostudio-icecast

# ─── Liquidsoap ──────────────────────────────────────────────────────────────
# Port that Liquidsoap's harbor() listens on for live broadcaster connections.
# Broadcasters point BUTT/OBS/Mixxx to this port instead of Icecast directly.
LIQUIDSOAP_HARBOR_PORT=8100

# ─── File limits ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=52428800

# ─── Google Drive (folder-based import) ──────────────────────────────────────
# Service account JSON key downloaded from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Root "Music" folder ID — the shared folder you gave the service account access to.
# Each station automatically gets its own sub-folder named after the station inside it.
# Your root folder: https://drive.google.com/drive/folders/1qkI_OynDm9ril8hqF82nXTvQ9H6xrHbp
GOOGLE_DRIVE_FOLDER_ID=1qkI_OynDm9ril8hqF82nXTvQ9H6xrHbp

# Set to 'gdrive' to also use Drive for file-upload storage (the Drive Import feature
# works regardless of this value — it only controls where uploaded files go).
STORAGE_BACKEND=gdrive
