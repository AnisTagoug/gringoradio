# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:npg_Vvb3WkezPB5Q@ep-muddy-poetry-a87fg4rz-pooler.eastus2.azure.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT — CHANGE THIS in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://gringoo-three.vercel.app

# ─── STORAGE BACKEND ──────────────────────────────────────────────────────────
# Choose one: local | gdrive | r2
# Start with "local" — no setup needed. Switch later by changing this one line.
STORAGE_BACKEND=local

# Used when STORAGE_BACKEND=local
# This is the public URL of your backend server (for building file URLs)
BACKEND_URL=http://localhost:5000

# ─── Google Drive (free 15 GB, no credit card) ────────────────────────────────
# Set STORAGE_BACKEND=gdrive and follow the steps in googleDriveService.js
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ─── Cloudflare R2 (free 10 GB, needs card for verification) ──────────────────
# Set STORAGE_BACKEND=r2 and fill these in
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=radiostudio-audio
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXX.r2.dev

# ─── yt-dlp (YouTube extraction) ──────────────────────────────────────────────
# Windows: if yt-dlp.exe is NOT in PATH, set the full path here:
# YT_DLP_PATH=C:\Users\Anis\yt-dlp.exe
#
# Or better: move yt-dlp.exe to C:\Windows\System32\ and leave this commented out
YT_DLP_PATH=yt-dlp

# ─── Icecast ──────────────────────────────────────────────────────────────────
ICECAST_HOST=68.210.100.174
ICECAST_INTERNAL_PORT=8000
ICECAST_PORT=8000
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=adminpass123
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_CONTAINER_NAME=radiostudio-icecast

# ─── Liquidsoap ───────────────────────────────────────────────────────────────
LIQUIDSOAP_HARBOR_PORT=8100

# ─── File limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=52428800
LIQUIDSOAP_PATH=liquidsoap
FFMPEG_PATH=/usr/bin/ffmpeg
SKIP_DOCKER=true
YT_DLP_COOKIES=/home/azureuser/backend/cookies.txt
